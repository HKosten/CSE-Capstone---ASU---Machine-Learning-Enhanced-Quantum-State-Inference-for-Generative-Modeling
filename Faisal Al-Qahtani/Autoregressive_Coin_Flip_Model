        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# 0 = tails, 1 = heads\n",
        "# Generate coin flip sequences based on probabilities\n",
        "def generate_sequence(p_heads_given_heads, p_heads_given_tails, length=50):\n",
        "    seq = [torch.randint(0, 2, (1,)).item()]\n",
        "    for _ in range(length - 1):\n",
        "        if seq[-1] == 1:\n",
        "            next_flip = 1 if torch.rand(1).item() < p_heads_given_heads else 0\n",
        "        else:\n",
        "            next_flip = 1 if torch.rand(1).item() < p_heads_given_tails else 0\n",
        "        seq.append(next_flip)\n",
        "    return seq\n",
        "\n",
        "# Model\n",
        "class MarkovChain(torch.nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.t_logits = torch.nn.Embedding(2, 2)\n",
        "    def forward(self, x):\n",
        "        return self.t_logits(x)\n",
        "\n",
        "# Training data: sequences where heads follows heads 90% of the time\n",
        "data = []\n",
        "for _ in range(100):\n",
        "    seq = generate_sequence(0.9, 0.1)\n",
        "    data.append(torch.tensor(seq))\n",
        "\n",
        "# Train\n",
        "model = MarkovChain()\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=0.01)\n",
        "\n",
        "for epoch in range(500):\n",
        "    loss_total = 0\n",
        "    for seq in data:\n",
        "        x = seq[:-1]\n",
        "        y = seq[1:]\n",
        "        logits = model(x)\n",
        "        loss = F.cross_entropy(logits, y)\n",
        "        optimizer.zero_grad()\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "        loss_total += loss.item()\n",
        "    if epoch % 100 == 0:\n",
        "        print(f\"Epoch {epoch}, Loss: {loss_total/len(data):.4f}\")\n",
        "\n",
        "# Results: learned probabilities\n",
        "probs = torch.softmax(model.t_logits.weight, dim=1)\n",
        "print(\"\\nLearned probabilities:\")\n",
        "print(f\"After tails  -> P(heads): {probs[0][1].item():.2f}, P(tails): {probs[0][0].item():.2f}\")\n",
        "print(f\"After heads  -> P(heads): {probs[1][1].item():.2f}, P(tails): {probs[1][0].item():.2f}\")"
      ]
